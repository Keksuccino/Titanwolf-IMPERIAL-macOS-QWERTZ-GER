{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Use Windows DEL as Move to Trash in Finder",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.apple\\.finder$"
                                        ],
                                        "type": "frontmost_application_if"
                                    },
                                    {
                                        "expression": "accessibility.focused_ui_element.role_string like 'AXText*'",
                                        "type": "expression_unless"
                                    }
                                ],
                                "from": {
                                    "key_code": "delete_forward",
                                    "modifiers": { "optional": ["caps_lock"] }
                                },
                                "to": [
                                    {
                                        "key_code": "delete_or_backspace",
                                        "modifiers": ["left_command"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "devices": [
                {
                    "identifiers": {
                        "is_keyboard": true,
                        "product_id": 11503,
                        "vendor_id": 7805
                    },
                    "ignore": true
                },
                {
                    "fn_function_keys": [
                        {
                            "from": { "key_code": "f1" },
                            "to": [{ "consumer_key_code": "al_consumer_control_configuration" }]
                        },
                        {
                            "from": { "key_code": "f2" },
                            "to": [{ "consumer_key_code": "volume_decrement" }]
                        },
                        {
                            "from": { "key_code": "f3" },
                            "to": [{ "consumer_key_code": "volume_increment" }]
                        },
                        {
                            "from": { "key_code": "f4" },
                            "to": [{ "consumer_key_code": "mute" }]
                        },
                        {
                            "from": { "key_code": "f5" },
                            "to": [{ "consumer_key_code": "play_or_pause" }]
                        },
                        {
                            "from": { "key_code": "f6" },
                            "to": [{ "consumer_key_code": "rewind" }]
                        },
                        {
                            "from": { "key_code": "f7" },
                            "to": [{ "consumer_key_code": "play_or_pause" }]
                        },
                        {
                            "from": { "key_code": "f8" },
                            "to": [{ "consumer_key_code": "fast_forward" }]
                        },
                        {
                            "from": { "key_code": "f9" },
                            "to": [{ "consumer_key_code": "al_email_reader" }]
                        },
                        {
                            "from": { "key_code": "f10" },
                            "to": [{ "consumer_key_code": "al_local_machine_browser" }]
                        },
                        {
                            "from": { "key_code": "f11" },
                            "to": [{ "consumer_key_code": "al_calculator" }]
                        },
                        {
                            "from": { "key_code": "f12" },
                            "to": [{ "apple_vendor_keyboard_key_code": "spotlight" }]
                        }
                    ],
                    "identifiers": {
                        "is_keyboard": true,
                        "product_id": 34067,
                        "vendor_id": 3141
                    },
                    "ignore_vendor_events": true
                }
            ],
            "name": "Default profile",
            "selected": true,
            "simple_modifications": [
                {
                    "from": { "key_code": "left_command" },
                    "to": [{ "key_code": "left_control" }]
                },
                {
                    "from": { "key_code": "left_control" },
                    "to": [{ "key_code": "left_command" }]
                },
                {
                    "from": { "key_code": "right_command" },
                    "to": [{ "key_code": "right_control" }]
                },
                {
                    "from": { "key_code": "right_control" },
                    "to": [{ "key_code": "right_command" }]
                }
            ],
            "virtual_hid_keyboard": {
                "caps_lock_delay_milliseconds": 0,
                "keyboard_type": "iso",
                "keyboard_type_v2": "ansi"
            }
        }
    ]
}